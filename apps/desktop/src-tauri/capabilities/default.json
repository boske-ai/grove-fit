{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Grove Fit default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-detect-hardware",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/llmfit",
          "sidecar": true,
          "args": ["--json", "system"]
        }
      ]
    }
  ]
}
