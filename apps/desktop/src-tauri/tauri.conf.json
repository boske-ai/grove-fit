{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove Fit",
  "version": "0.1.0",
  "identifier": "dev.boske.grove-fit",
  "build": {
    "beforeDevCommand": "bun run --cwd ../web dev",
    "devUrl": "http://127.0.0.1:3847",
    "beforeBuildCommand": "bun run --cwd ../web build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Grove Fit",
        "width": 780,
        "height": 600,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost https://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/llmfit"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
